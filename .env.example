# sync-tools 配置文件模板
# 复制此文件为 .env 并按需修改
# 修改后无需重启，每次运行脚本时自动读取

# ── 项目根目录（可选）────────────────────────────────────────────
# 默认自动推断（脚本所在位置向上一级：sync-tools -> 根）
# 如果 sync-tools 不在项目根目录下，请在此手动指定绝对路径
# ROOT=D:/MyProject

# ── Python 环境 ───────────────────────────────────────────────────
# 项目虚拟环境中 python.exe 的路径（相对于项目根目录，或绝对路径）
VENV_PYTHON=.venv/Scripts/python.exe

# ── 项目目录结构 ──────────────────────────────────────────────────
# 以下路径均相对于项目根目录（也可填绝对路径）

# 临时工作目录（打包时复制差异文件用）
TEMP_DIR=sync-tools/temp

# 软删除目录（被删除的文件移入此处，不永久删除）
RM_DIR=sync-tools/rm

# 输出目录（历史清单存档等）
FILE_DIR=sync-tools/file_history

# 清单存档子目录（相对于 FILE_DIR）
MANIFESTS_SUBDIR=manifests

# ── 7-Zip ─────────────────────────────────────────────────────────
# 额外搜索路径（逗号分隔），脚本会先尝试 PATH 中的 7z，找不到再依次尝试这些路径
SEVEN_ZIP_EXTRA=C:/Program Files/7-Zip/7z.exe,C:/Program Files (x86)/7-Zip/7z.exe
