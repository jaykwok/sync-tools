# .syncignore — 增量同步忽略规则
# 将此文件复制到项目根目录并重命名为 .syncignore，按需修改。
#
# 规则格式：
#   dir:<路径>   忽略目录
#                - 单段名称（如 dir:.venv）可匹配任意层级的同名目录
#                - 多段路径（如 dir:sync-tools/rm）精确匹配该路径
#   file:<glob>  忽略文件名，支持 * 通配符
#
# 空行和 # 开头的行视为注释，忽略不计。

# ── 工具目录（必须保留，否则 sync-tools 自身会被打包进清单）────────
dir:sync-tools

# ── 开发环境 ─────────────────────────────────────────────────────
dir:.venv
dir:.git
dir:node_modules
dir:__pycache__

# ── AI 工具配置（个人，不建议同步到云端）────────────────────────
dir:.claude

# ── 清单文件 & 同步产物（运行时产物，不需要同步）─────────────
file:*manifest*.json.xz
file:*.7z*

# ── 系统 / 临时文件 ───────────────────────────────────────────────
file:Thumbs.db
file:desktop.ini
file:*.log
file:*.pyc
file:*.tmp
